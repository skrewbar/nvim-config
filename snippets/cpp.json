  "C++ multi testcase template": {
    "scope": "cpp",
    "prefix": "tcinit",
    "body": [
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "void solve() {",
      "    $0",
      "}",
      "",
      "int main() {",
      "    ios::sync_with_stdio(false);",
      "    cin.tie(nullptr);",
      "",
      "    int t;",
      "    cin >> t;",
      "",
      "    while (t--)",
